# Site URL (canonical, OG, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://arbuilding-ambrosoni.netlify.app

# Airtable
AIRTABLE_TOKEN=pat_xxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxx
AIRTABLE_TABLE_ID=tblxxxxxxxxxxxx

# Web3Forms (form de contacto)
# Destinatario final: info@arbuilding.com.ar (configurado en el dashboard de Web3Forms, no acá)
# Prefijo NEXT_PUBLIC_ requerido: el POST se hace desde el cliente (Cloudflare bloquea fetch server-side).
# La access key es publica por diseño — Web3Forms la declara safe en client-side code.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=xxxxxxxxxxxx